Velociraptor{{{
	Documentation{{{
		https://docs.velociraptor.app/
	}}}
	Installation{{{
		Server{{{
			Windows{{{
				Prereq{{{
					- adminsistrative access
					- windows server or windows 10/11
					- latest binary - https://github.com/Velocidex/velociraptor
				}}}
				Steps{{{
					## create a folder and place the binary in the new directory
					## generate config file
						PS#> velociraptor-v...exe config generate > server.config.yaml
					!! modify the server.config.yaml to configure TLS, set the frontend url, and define users!!
					## create server service
						velociraptor.exe --config server.config.yaml service install
						net start Velociraptor
					## access the GUI
						open a web browser and navigate to the URL configured in step 2 (default: http://localhost:8889)
				}}}
				Post-install{{{
					- firewall - Ensure Windows Firewall allows traffic on TCP ports 8889 (GUI) and 8000 (Clients).
					- Logging -  View logs in the Event Viewer or the designated log file path in the config. 
				}}}
			}}}
			Linux{{{
				Prereq{{{
					- Linux server must be Ubunyu/Debian or RHEL/Rocky Linux
					- Sudo privs
				}}}
				Steps{{{
					## download the binary
						wget https://github.com/Velocidex/velociraptor/releases/download/v0.76/velociraptor-v0.76.1-linux-amd64
					## install and set permissions
						mv velociraptor-v0.74.1-linux-amd64 /usr/local/bin/velociraptor
						chmod +x /usr/local/bin/velociraptor
					## generate configuration (making any changes as needed) 
						velociraptor config generate -i
						nano server.config.yaml
					## create service
						nano /lib/systemd/system/velociraptor.service
						!! paste the following !! ## adjust the '--config' path to where you saved the config file (server.config.yaml)
							[Unit]
							Description=Velociraptor linux amd64
							After=syslog.target network.target

							[Service]
							Type=simple
							Restart=always
							RestartSec=120
							LimitNOFILE=20000
							Environment=LANG=en_US.UTF-8
							ExecStart=/usr/local/bin/velociraptor --config /etc/velociraptor/server.config.yaml frontend -v

							[Install]
							WantedBy=multi-user.target
					## start the service
						systemctl daemon-reload
						systemctl enable --now velociraptor
					## access the GUI
						open a web browser and navigate to the GUI address configured in step 3 (default: http://localhost:8889)
				}}}
				Post-install{{{
					- firewall - ensure ports 8889 (GUI) and 8000 (Clients) are open
					- create clients - use the 'velociraptor client' command to generate config files for endpoints
				}}}				
			}}}
		}}}
		Client{{{
			Windows{{{
				## from the Velociraptor Admin GUI, go to server atifacts
				## click the + button to create a new collection
				## search for 'Serevr.Utils.CreateMSI', select it and click launch
				## the repacked msi file will appear in the 'Uploaded Files' tab
				## download and transfer the MSI file to the windows endpoint (USB, Sharedrive, etc.)
				## run the MSI
					!! it will appear to complete silently. check services to see if it is installed and running!!
				## in the velociraptor gui, you should see n+1 connected client(s)
			}}}
			Linux{{{
			
			}}}
		}}}
	}}}
